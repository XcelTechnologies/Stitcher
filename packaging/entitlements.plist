<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- PyInstaller's bootloader maps executable pages; allow it under the
         hardened runtime that notarization requires. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- The frozen app loads Python C-extensions / Qt dylibs that aren't part
         of the main signed executable's team. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
</dict>
</plist>
